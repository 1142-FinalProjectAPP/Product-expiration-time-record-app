<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    tools:context=".InventoryFragment">

    <!-- Top Search Bar -->
    <com.google.android.material.search.SearchBar
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="搜尋存貨"
        android:layout_margin="16dp" />

    <!-- Chip Filter -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="所有商品"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="即將過期"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最近新增"
            app:chipCornerRadius="20dp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="即將過期"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvSoonExpireCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 件"
                            android:textColor="#222222"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="浪費率(過期)"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvWasteRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0%"
                            android:textColor="#D84315"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- 標題 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="存貨類別分佈"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222222"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleChart"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="圓"/>
            </LinearLayout>

            <!-- 🔥 PieChart（你 Java 會用到） -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:visibility="gone"/>

            <!-- 🔥 Progress 包起來（你 Java 會控制它顯示/隱藏） -->
            <LinearLayout
                android:id="@+id/progressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 蔬菜 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="蔬菜"
                        android:textColor="#444444"/>

                    <TextView
                        android:id="@+id/tvVegPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25%"
                        android:textColor="#444444"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbVeg"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="25"
                    android:max="100"
                    android:progressTint="#00C853"
                    android:backgroundTint="#E0E0E0"/>

                <!-- 其他 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="其他"/>

                    <TextView
                        android:id="@+id/tvOtherPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="36%"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbOther"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="36"
                    android:max="100"
                    android:progressTint="#7E57C2"
                    android:backgroundTint="#E0E0E0"/>

                <!-- 飲料 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="飲料"/>

                    <TextView
                        android:id="@+id/tvDrinkPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22%"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbDrink"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="22"
                    android:max="100"
                    android:progressTint="#FF7043"
                    android:backgroundTint="#E0E0E0"/>

                <!-- 乳製品 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="乳製品"/>

                    <TextView
                        android:id="@+id/tvDairyPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17%"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbDairy"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="17"
                    android:max="100"
                    android:progressTint="#64B5F6"
                    android:backgroundTint="#E0E0E0"/>

                <!-- 底部說明 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="基於目前 94 個存貨項目統計"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>